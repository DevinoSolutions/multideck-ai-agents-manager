# multideck environment variables — copy to .env and edit.
# Every MULTIDECK_* key must match a field in src/multideck/env.py;
# unknown MULTIDECK_ vars are a hard error (closed schema).

# Sentry DSN — set to enable error reporting (optional, default: off)
# MULTIDECK_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# Logging level — DEBUG, INFO, WARNING, ERROR, CRITICAL (default: none / library default)
# MULTIDECK_LOG_LEVEL=INFO
