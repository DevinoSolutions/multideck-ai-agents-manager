# multideck environment variables — set them in your environment, or copy
# this file to ~/.multideck/.env and edit. multideck reads ONLY that file,
# never the current directory's .env (which belongs to whatever project
# you happen to be standing in).
# Every MULTIDECK_* key must match a field in src/multideck/env.py;
# unknown MULTIDECK_ vars are a hard error (closed schema).

# Sentry DSN — set to enable error reporting (optional, default: off)
# MULTIDECK_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ntfy topic URL — set to push needs-input/error notifications to your phone
# via the attention daemon (optional, default: off; also needs settings.attention.ntfy)
# MULTIDECK_NTFY_TOPIC=https://ntfy.example.com/your-topic

# Logging level — DEBUG, INFO, WARNING, ERROR, CRITICAL (default: INFO when unset)
# MULTIDECK_LOG_LEVEL=INFO
